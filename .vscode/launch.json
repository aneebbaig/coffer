{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mobile: Debug",
      "cwd": "apps/mobile",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug"
    },
    {
      "name": "Mobile: Release",
      "cwd": "apps/mobile",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "name": "Web: Dev server (debug)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/apps/web",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Web: Production build (release)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run build && npm run start",
      "cwd": "${workspaceFolder}/apps/web",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  ]
}
