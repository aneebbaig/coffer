# ── Align — Environment Variables Template ──────────────────────────
# Copy to .env.local for local development.
# Set these in Vercel dashboard for production.

# Optional: override the app's display name (title, sidebar, login, PWA manifest).
# Defaults to "Align" if unset. Handy for private deployments / white-labeling.
NEXT_PUBLIC_APP_NAME="Align"

# ── Database (Neon PostgreSQL) ────────────────────────────────────────
# Get this from your Neon project → Connect → Prisma tab
# Use the dev branch URL for local dev, main branch URL for production
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-generated-secret"

# Your app URL (http://localhost:3000 for dev, https://your-domain.com for prod)
NEXTAUTH_URL="http://localhost:3000"

# ── User Accounts ─────────────────────────────────────────────────────
USER1_EMAIL="your-email@gmail.com"
USER1_PASSWORD="your-strong-password"
USER1_NAME="Admin"

USER2_EMAIL="spouse-email@gmail.com"
USER2_PASSWORD="spouse-strong-password"
USER2_NAME="Member"

# ── Gmail Email Alerts (optional) ────────────────────────────────────
# GMAIL_USER=your@gmail.com
# GMAIL_APP_PASSWORD=abcdefghijklmnop

# 32+ char random string. Encrypts TOTP secrets at rest. Generate: openssl rand -base64 32
TOTP_ENC_KEY="replace-with-openssl-rand-base64-32"

# better-auth (fleet auth standard). SECRET falls back to AUTH_SECRET/JWT_SECRET.
BETTER_AUTH_SECRET="generate: openssl rand -base64 32"
BETTER_AUTH_URL="https://your-app-domain.com"
